{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuotaDock",
  "version": "0.1.0",
  "identifier": "dev.quotadock.desktop",
  "build": {
    "beforeDevCommand": "pnpm frontend:dev",
    "beforeBuildCommand": "pnpm frontend:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QuotaDock",
        "width": 980,
        "height": 720,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
