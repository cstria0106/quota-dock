{
  "name": "quota-dock-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:windows": "pnpm frontend:build && cargo xwin build --release --locked --target x86_64-pc-windows-msvc --features custom-protocol",
    "frontend:dev": "vite --host 127.0.0.1 --port 1420 --strictPort",
    "frontend:build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tauri-apps/api": "^2.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
